---
// index.astro - Home page (Spanish default)
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-cempasuchil.jpg';
import omeImage from '../assets/images/ome-raiz-396hz.jpg';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('bitacora', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const categoryLabels: Record<string, string> = {
  'ensayos': 'Ensayo',
  'notas-de-campo': 'Nota de campo',
  'procesos': 'Proceso',
  'glosario': 'Glosario',
};

function formatDate(date: Date) {
  const months = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
  return `${date.getDate()} ${months[date.getMonth()]} ${date.getFullYear()}`;
}

const pageTitle = 'César Del Pino — Sonic Anthropologist · Sound Artist & Composer';
const pageDescription = 'César Del Pino — Sonic Anthropologist. Sound Artist & Composer con obra en Netflix, TNT Russia, Cirque du Soleil, Museo Rambalkoshe y estudio Kanye West. En la intersección de antropología, composición e ingeniería sonora.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang="es"
  schemaType="Person"
>

<!-- HERO -->
<section class="hero">
  <figure class="hero-image">
    <Image
      src={heroImage}
      alt="Retrato de espaldas en campo de cempasúchil al atardecer"
      width={1200}
      height={1200}
      quality={85}
      loading="eager"
      fetchpriority="high"
    />
  </figure>

  <div class="hero-corners-top">
    <div class="corner-label">
      <span class="dot"></span>
      Sonic Anthropologist
    </div>
    <div class="corner-label right">
      An ongoing inquiry
      <span class="dot"></span>
    </div>
  </div>

  <div class="hero-center">
    <h1 class="hero-manifesto">
      <span class="sentence">Soy <span class="name-gold">César Del Pino</span>.</span>
      <span class="sentence s-thin"><b>Productor</b> musical y compositor.</span>
    </h1>

    <div class="hero-rotator" aria-hidden="true">
      <span class="rotator-prefix">Hago <b>sonido</b> para</span>
      <div class="rotator-track">
        <span class="rword-spacer">investigaciones.</span>
        <span class="rword" style="--n:0">cine.</span>
        <span class="rword" style="--n:1">marcas.</span>
        <span class="rword" style="--n:2">museos.</span>
        <span class="rword" style="--n:3">clubes.</span>
        <span class="rword" style="--n:4">restaurantes.</span>
        <span class="rword" style="--n:5">experiencias.</span>
        <span class="rword" style="--n:6">redes sociales.</span>
        <span class="rword" style="--n:7">investigaciones.</span>
      </div>
    </div>

    <div class="hero-meta reveal">
      <div class="hero-meta-label">Selected works<br />2014—2026</div>
      <div class="hero-credentials">
        <div class="cred-role">He trabajado con:</div>
        <ul class="cred-works">
          <li>
            <span class="cw-name">Netflix</span>
            <span class="cw-tag">Score · 2020—</span>
          </li>
          <li>
            <span class="cw-name">Kanye West / Plaza de Toros</span>
            <span class="cw-tag">Studio Design · 2026</span>
          </li>
          <li>
            <span class="cw-name">Janax Pacha · Elea Colective</span>
            <span class="cw-tag">Producción e ingeniería · 2025</span>
          </li>
          <li>
            <span class="cw-name">AMMEV Congreso Doula</span>
            <span class="cw-tag">Experiencia sonora · General Prim · 2025</span>
          </li>
          <li>
            <span class="cw-name">Museo Rambalkoshe</span>
            <span class="cw-tag">Live Installation · Armenia · 2020</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-label">Scroll</span>
      <span class="scroll-line"></span>
      <span class="scroll-arrow">↓</span>
    </div>
  </div>

  <div class="hero-corners-bottom">
    <div class="corner-label bottom-left">
      <span class="dot"></span>
      Antropología
    </div>
    <div class="corner-label bottom-right">
      Sonido
      <span class="dot"></span>
    </div>
  </div>

</section>

<!-- WORKS / SELECTED WORKS -->
