---
// src/pages/paywalldesangre.astro
// Experiencia interactiva audio-reactiva para el track "Paywall de Sangre" de Ōme
// Standalone — no usa Header/Footer del sitio
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Paywall de Sangre — Ōme</title>
<meta name="description" content="Experiencia interactiva audio-reactiva del track Paywall de Sangre de Ōme.">
<meta property="og:title" content="Paywall de Sangre — Ōme">
<meta property="og:description" content="Experiencia interactiva audio-reactiva.">
<meta property="og:image" content="/audio/paywalldesangre-cover.jpg">
<style>
  :root{
    --vacio:#08060a;
    --obsidiana:#14101a;
    --sangre-vieja:#3d0a0a;
    --sangre-fresca:#a8121a;
    --plata:#c8c4be;
    --hueso:#e8e0d4;
    --tinta:#6a6660;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{height:100%;background:var(--vacio);overflow:hidden;
    font-family:'Georgia','Times New Roman',serif;color:var(--hueso);
    -webkit-tap-highlight-color:transparent;}
  canvas{display:block;position:fixed;inset:0;}

  /* ---- pantalla de entrada ---- */
  #portada{position:fixed;inset:0;z-index:20;display:flex;
    flex-direction:column;align-items:center;justify-content:center;
    background:radial-gradient(ellipse at 50% 55%, #1a0a12 0%, #08060a 75%);
    transition:opacity 1.4s ease;text-align:center;padding:8vw;}
  #portada.fuera{opacity:0;pointer-events:none;}
  .artista{font-size:clamp(11px,1.8vw,14px);letter-spacing:.6em;
    text-transform:uppercase;color:var(--tinta);margin-bottom:2.4rem;
    padding-left:.6em;}
  .titulo{font-size:clamp(40px,9vw,112px);line-height:.95;
    color:var(--hueso);font-weight:400;letter-spacing:-.015em;
    text-shadow:0 0 80px rgba(168,18,26,.3);}
  .titulo em{font-style:italic;color:var(--sangre-fresca);}
  .iniciar{margin-top:3.4rem;background:none;cursor:pointer;
    border:1px solid var(--sangre-vieja);color:var(--hueso);
    font-family:inherit;font-size:clamp(11px,2vw,13px);
    letter-spacing:.28em;text-transform:uppercase;padding:1.2em 2.6em;
    border-radius:999px;transition:all .5s ease;}
  .iniciar:hover{background:var(--sangre-vieja);color:var(--hueso);
    border-color:var(--sangre-fresca);
    box-shadow:0 0 60px rgba(168,18,26,.4);}
  .pie{margin-top:2.6rem;font-size:10px;color:var(--tinta);
    letter-spacing:.16em;text-transform:uppercase;}

  /* ---- HUD durante la experiencia ---- */
  #hud{position:fixed;z-index:15;inset:0;pointer-events:none;
    opacity:0;transition:opacity 1.6s ease;}
  #hud.dentro{opacity:1;}
  .esquina{position:absolute;font-size:11px;letter-spacing:.22em;
    text-transform:uppercase;color:var(--tinta);}
  .arr-izq{top:4vw;left:4vw;}
  .arr-der{top:4vw;right:4vw;text-align:right;}
  .titulo-hud{color:var(--hueso);font-size:13px;letter-spacing:.18em;}
  .artista-hud{color:var(--sangre-fresca);font-style:italic;font-size:11px;
    text-transform:none;letter-spacing:.05em;margin-top:.3em;}

  /* botones de redes abajo */
  .redes{position:absolute;bottom:4vw;left:50%;transform:translateX(-50%);
    display:flex;gap:1.2em;pointer-events:auto;flex-wrap:wrap;
    justify-content:center;}
  .red{font-family:inherit;font-size:11px;letter-spacing:.22em;
    text-transform:uppercase;color:var(--hueso);text-decoration:none;
    border:1px solid var(--sangre-vieja);padding:.9em 1.6em;
    border-radius:999px;transition:all .4s ease;background:rgba(8,6,10,.6);
    backdrop-filter:blur(4px);}
  .red:hover{background:var(--sangre-vieja);border-color:var(--sangre-fresca);
    box-shadow:0 0 30px rgba(168,18,26,.3);}
  .red em{font-style:italic;color:var(--sangre-fresca);
    text-transform:none;letter-spacing:.04em;margin-left:.4em;}

  /* control de volumen */
  .vol{position:absolute;top:4vw;right:4vw;pointer-events:auto;
    display:flex;align-items:center;gap:.8em;}
  .vol input{-webkit-appearance:none;appearance:none;width:90px;height:1px;
    background:var(--sangre-vieja);outline:none;}
  .vol input::-webkit-slider-thumb{-webkit-appearance:none;width:11px;
    height:11px;border-radius:50%;background:var(--sangre-fresca);cursor:pointer;}
  .vol input::-moz-range-thumb{width:11px;height:11px;border:none;
    border-radius:50%;background:var(--sangre-fresca);cursor:pointer;}
  .vol span{font-size:9px;letter-spacing:.22em;color:var(--tinta);}

  .pista-nota{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);
    font-size:10px;letter-spacing:.18em;color:rgba(200,196,190,.25);
    text-align:center;text-transform:uppercase;opacity:0;
    transition:opacity 1.2s ease;pointer-events:none;}
  .pista-nota.aparece{opacity:1;}

  @media (max-width:640px){
    .arr-der{display:none;}
    .vol{top:auto;bottom:14vw;right:50%;transform:translateX(50%);}
    .redes{bottom:6vw;gap:.6em;}
    .red{font-size:10px;padding:.8em 1.2em;}
  }
</style>
</head>
<body>

<canvas id="lienzo"></canvas>

<!-- HUD durante la experiencia -->
<div id="hud">
  <div class="esquina arr-izq">
    <div class="titulo-hud">Paywall de Sangre</div>
    <div class="artista-hud">Ōme</div>
  </div>
  <div class="vol">
    <span>VOL</span>
    <input type="range" id="vol" min="0" max="1" step="0.01" value="0.85">
  </div>
  <div class="pista-nota" id="pista-nota">mueve · toca · sangra</div>
  <div class="redes">
    <a class="red" href="https://soundcloud.com/omemusic/paywall-sangre" target="_blank" rel="noopener">
      Escucha en <em>SoundCloud</em>
    </a>
    <a class="red" href="https://instagram.com/omemusicmx" target="_blank" rel="noopener">
      Sígueme en <em>Instagram</em>
    </a>
  </div>
</div>

<!-- Portada -->
<div id="portada">
  <div class="artista">Ōme</div>
  <h1 class="titulo">Paywall <em>de Sangre</em></h1>
  <button class="iniciar" id="btn">Iniciar experiencia · Autorizo reproducción de audio</button>
  <p class="pie">7 min · usa audífonos</p>
</div>

<audio id="audio" preload="auto" crossorigin="anonymous">
  <source src="/audio/paywalldesangre.mp3" type="audio/mpeg">
</audio>

<script>
/* ============================================================
   PAYWALL DE SANGRE — experiencia interactiva
   Estructura: rejilla rectangular ("el paywall") que late
   con los graves del track. El mouse/toque hace que las
   intersecciones cercanas SANGREN (gotean hacia abajo).
   Cada click deja una mancha permanente.
   ============================================================ */

/* ---------- 1. AUDIO Y FFT ---------- */
let ctx, analizador, datos, fuente, ganancia;
const audioEl = document.getElementById('audio');

function arrancarAudio(){
  ctx = new (window.AudioContext||window.webkitAudioContext)();
  fuente = ctx.createMediaElementSource(audioEl);
  ganancia = ctx.createGain();
  ganancia.gain.value = 0.85;
  analizador = ctx.createAnalyser();
  analizador.fftSize = 1024;
  datos = new Uint8Array(analizador.frequencyBinCount);
  fuente.connect(ganancia);
  ganancia.connect(analizador);
  analizador.connect(ctx.destination);
  audioEl.play().catch(e=>console.warn('audio play:',e));
}

function leerAudio(){
  if(!analizador) return {grave:0,medio:0,agudo:0,kick:0};
  analizador.getByteFrequencyData(datos);
  let g=0,m=0,a=0,k=0;
  const n=datos.length;
  const c1=Math.floor(n*.08), c2=Math.floor(n*.35);
  // kick: solo los primeros 4 bins (sub-bass / kick fundamental)
  for(let i=0;i<4;i++) k=Math.max(k,datos[i]);
  for(let i=0;i<c1;i++) g+=datos[i];
  for(let i=c1;i<c2;i++) m+=datos[i];
  for(let i=c2;i<n;i++) a+=datos[i];
  return {
    grave:g/(c1*255),
    medio:m/((c2-c1)*255),
    agudo:a/((n-c2)*255),
    kick:k/255
  };
}

/* ---------- 2. CANVAS Y LA REJILLA ---------- */
const lienzo = document.getElementById('lienzo');
const cx = lienzo.getContext('2d');
let W,H,DPR;
function medir(){
  DPR = Math.min(devicePixelRatio||1, 2);
  W = lienzo.width = innerWidth*DPR;
  H = lienzo.height = innerHeight*DPR;
  lienzo.style.width = innerWidth+'px';
  lienzo.style.height = innerHeight+'px';
}
addEventListener('resize', medir); medir();

/* La rejilla — el paywall literal */
const COLS = 22;
const FILAS = 14;
let nodos = [];           // intersecciones de la rejilla
let gotas = [];           // gotas que caen desde las intersecciones tocadas
let manchas = [];         // manchas permanentes de clicks/taps
let raton = {x:-1,y:-1,activo:false,vx:0,vy:0,px:0,py:0};
let suaveG=0, suaveM=0, suaveA=0, suaveK=0, pulso=0, pulsoUlt=0;

function construirNodos(){
  nodos = [];
  for(let f=0;f<=FILAS;f++){
    for(let c=0;c<=COLS;c++){
      nodos.push({
        cx:c/COLS,        // posición relativa 0..1
        cy:f/FILAS,
        ofX:0, ofY:0,     // offset por interacción
        sangre:0          // cantidad de sangre acumulada en este nodo
      });
    }
  }
}
construirNodos();

/* ---------- 3. INTERACCIÓN ---------- */
function pos(e){
  const t = e.touches ? e.touches[0] : e;
  return {x:t.clientX*DPR, y:t.clientY*DPR};
}
function mover(e){
  const p = pos(e);
  raton.vx = p.x-raton.px; raton.vy = p.y-raton.py;
  raton.px = p.x; raton.py = p.y;
  raton.x = p.x; raton.y = p.y; raton.activo = true;

  // los nodos cercanos sangran
  const radio = Math.min(W,H)*0.12;
  for(const n of nodos){
    const nx = n.cx*W, ny = n.cy*H;
    const d = Math.hypot(nx-p.x, ny-p.y);
    if(d < radio){
      const fuerza = (1 - d/radio);
      n.sangre = Math.min(1, n.sangre + fuerza*0.06);
      // empuja el nodo levemente
      const ang = Math.atan2(ny-p.y, nx-p.x);
      n.ofX += Math.cos(ang)*fuerza*2;
      n.ofY += Math.sin(ang)*fuerza*2;
      // probabilidad de gotear
      if(Math.random() < fuerza*0.15){
        gotas.push({
          x:nx + n.ofX, y:ny + n.ofY,
          vy:0.5+Math.random()*1.2,
          vida:1, ancho:1+Math.random()*1.2
        });
      }
    }
  }
  if(gotas.length > 220) gotas.splice(0, gotas.length-220);
}
function manchar(e){
  const p = pos(e);
  manchas.push({
    x:p.x, y:p.y,
    r:8+Math.random()*14,
    op:0.85,
    chorros: Array.from({length:3+Math.floor(Math.random()*4)}, ()=>({
      ang: Math.random()*Math.PI*2,
      largo: 15+Math.random()*40,
      ancho: 1+Math.random()*2
    }))
  });
  if(manchas.length > 60) manchas.shift();
}
lienzo.addEventListener('mousemove', mover);
lienzo.addEventListener('mousedown', e=>{manchar(e); mover(e);});
lienzo.addEventListener('touchmove', e=>{e.preventDefault(); mover(e);}, {passive:false});
lienzo.addEventListener('touchstart', e=>{e.preventDefault(); manchar(e); mover(e);}, {passive:false});

/* ---------- 4. LOOP DE DIBUJO ---------- */
function dibujar(){
  requestAnimationFrame(dibujar);
  const a = leerAudio();
  suaveG += (a.grave-suaveG)*0.14;
  suaveM += (a.medio-suaveM)*0.18;
  suaveA += (a.agudo-suaveA)*0.25;
  suaveK += (a.kick-suaveK)*0.4;

  // detectar pico de kick para pulso visual
  if(a.kick > 0.55 && a.kick > pulsoUlt) pulso = 1;
  pulsoUlt = a.kick;
  pulso *= 0.88;

  // velo translúcido = persistencia + estela
  cx.fillStyle = `rgba(8,6,10,${0.18 + pulso*0.05})`;
  cx.fillRect(0,0,W,H);

  // breath del fondo: tinte sangre sutil con los graves
  if(suaveG > 0.15){
    cx.fillStyle = `rgba(61,10,10,${suaveG*0.04})`;
    cx.fillRect(0,0,W,H);
  }

  /* --- la rejilla (el paywall) --- */
  const lineWidth = (0.6 + suaveG*1.4 + pulso*0.8)*DPR;
  cx.lineWidth = lineWidth;
  const baseLum = 22 + suaveG*14 + pulso*16;
  cx.strokeStyle = `hsl(0 50% ${baseLum}%)`;

  // relajar offsets de los nodos
  for(const n of nodos){
    n.ofX *= 0.92; n.ofY *= 0.92;
    n.sangre *= 0.992;
  }

  // líneas horizontales
  cx.beginPath();
  for(let f=0;f<=FILAS;f++){
    for(let c=0;c<COLS;c++){
      const n1 = nodos[f*(COLS+1)+c];
      const n2 = nodos[f*(COLS+1)+c+1];
      const x1 = n1.cx*W+n1.ofX, y1 = n1.cy*H+n1.ofY;
      const x2 = n2.cx*W+n2.ofX, y2 = n2.cy*H+n2.ofY;
      cx.moveTo(x1,y1); cx.lineTo(x2,y2);
    }
  }
  cx.stroke();

  // líneas verticales
  cx.beginPath();
  for(let c=0;c<=COLS;c++){
    for(let f=0;f<FILAS;f++){
      const n1 = nodos[f*(COLS+1)+c];
      const n2 = nodos[(f+1)*(COLS+1)+c];
      const x1 = n1.cx*W+n1.ofX, y1 = n1.cy*H+n1.ofY;
      const x2 = n2.cx*W+n2.ofX, y2 = n2.cy*H+n2.ofY;
      cx.moveTo(x1,y1); cx.lineTo(x2,y2);
    }
  }
  cx.stroke();

  // intersecciones que sangran
  for(const n of nodos){
    if(n.sangre > 0.04){
      const nx = n.cx*W+n.ofX, ny = n.cy*H+n.ofY;
      cx.fillStyle = `hsla(0 75% ${30+n.sangre*25}% / ${n.sangre})`;
      cx.beginPath();
      cx.arc(nx, ny, (1.5+n.sangre*4)*DPR, 0, 6.28);
      cx.fill();
    }
  }

  /* --- gotas que caen --- */
  for(let i=gotas.length-1;i>=0;i--){
    const g = gotas[i];
    g.y += g.vy*DPR*(1+suaveK*0.5);
    g.vy += 0.05;
    g.vida -= 0.005;
    if(g.vida <= 0 || g.y > H+20){ gotas.splice(i,1); continue; }
    cx.strokeStyle = `hsla(0 70% ${28+suaveA*15}% / ${g.vida*0.85})`;
    cx.lineWidth = g.ancho*DPR;
    cx.beginPath();
    cx.moveTo(g.x, g.y-g.vy*3);
    cx.lineTo(g.x, g.y);
    cx.stroke();
  }

  /* --- manchas permanentes (clicks/taps) --- */
  for(const m of manchas){
    // mancha central
    const grad = cx.createRadialGradient(m.x, m.y, 0, m.x, m.y, m.r*DPR);
    grad.addColorStop(0, `hsla(0 78% 32% / ${m.op})`);
    grad.addColorStop(0.5, `hsla(0 65% 22% / ${m.op*0.7})`);
    grad.addColorStop(1, 'hsla(0 50% 12% / 0)');
    cx.fillStyle = grad;
    cx.beginPath();
    cx.arc(m.x, m.y, m.r*DPR, 0, 6.28);
    cx.fill();
    // chorros
    cx.strokeStyle = `hsla(0 70% 25% / ${m.op*0.8})`;
    cx.lineWidth = 1.4*DPR;
    for(const ch of m.chorros){
      cx.beginPath();
      cx.moveTo(m.x, m.y);
      cx.lineTo(m.x+Math.cos(ch.ang)*ch.largo*DPR, m.y+Math.sin(ch.ang)*ch.largo*DPR);
      cx.stroke();
    }
  }

  /* --- estela del cursor --- */
  if(raton.activo){
    const vel = Math.hypot(raton.vx, raton.vy);
    cx.fillStyle = `hsla(0 85% 45% / ${Math.min(0.7, vel/40)})`;
    cx.beginPath();
    cx.arc(raton.x, raton.y, (2+vel/10)*DPR, 0, 6.28);
    cx.fill();
  }
  raton.vx *= 0.82; raton.vy *= 0.82;
}
dibujar();

/* ---------- 5. CONTROLES ---------- */
document.getElementById('btn').addEventListener('click', ()=>{
  arrancarAudio();
  document.getElementById('portada').classList.add('fuera');
  document.getElementById('hud').classList.add('dentro');
  setTimeout(()=>{
    document.getElementById('pista-nota').classList.add('aparece');
    setTimeout(()=>{
      document.getElementById('pista-nota').classList.remove('aparece');
    }, 4000);
  }, 1500);
});

document.getElementById('vol').addEventListener('input', e=>{
  if(ganancia) ganancia.gain.value = parseFloat(e.target.value);
});

// Cuando termina el track, fade de la rejilla pero las manchas se quedan
audioEl.addEventListener('ended', ()=>{
  document.getElementById('pista-nota').textContent = 'la transmisión termina · las manchas quedan';
  document.getElementById('pista-nota').classList.add('aparece');
});
</script>
</body>
</html>
