---
// src/pages/paywalldesangre.astro
// Paywall de Sangre v4 — editorial design, English copy, bongos on portada
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>Paywall de Sangre — Ōme</title>
<meta name="description" content="An interactive audio-reactive experience for the track Paywall de Sangre by Ōme.">
<meta property="og:title" content="Paywall de Sangre — Ōme">
<meta property="og:description" content="An interactive audio-reactive experience.">
<meta property="og:image" content="/audio/paywalldesangre-cover.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --vacio:#06040a;
    --vino-oscuro:#2a0710;
    --vino:#5a0e1c;
    --vino-claro:#8a1a2a;
    --sangre:#a8121a;
    --sangre-bright:#d62828;
    --plata:#c8c4be;
    --hueso:#f0e8dc;
    --tinta:#8a847c;
    --serif:'Cormorant Garamond', serif;
    --sans:'Inter', system-ui, sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{height:100%;background:var(--vacio);overflow:hidden;
    font-family:var(--serif);color:var(--hueso);
    -webkit-tap-highlight-color:transparent;
    -webkit-touch-callout:none;
    user-select:none;-webkit-user-select:none;}
  canvas{display:block;position:fixed;inset:0;}

  /* ============================================
     PORTADA — editorial, cover as fullscreen bg
     ============================================ */
  #portada{position:fixed;inset:0;z-index:30;
    transition:opacity 1.6s ease;
    overflow:hidden;}
  #portada.fuera{opacity:0;pointer-events:none;}

  /* cover de fondo */
  .portada-bg{position:absolute;inset:0;
    background:url('/audio/paywalldesangre-cover.png') center/cover no-repeat;
    filter:blur(2px) saturate(.85) brightness(.5);
    transform:scale(1.1);
    animation:bg-breathe 18s ease-in-out infinite alternate;}
  @keyframes bg-breathe{
    0%{transform:scale(1.08);filter:blur(2px) saturate(.85) brightness(.5);}
    100%{transform:scale(1.15);filter:blur(4px) saturate(.9) brightness(.42);}
  }
  .portada-overlay{position:absolute;inset:0;
    background:
      radial-gradient(ellipse at 50% 55%, rgba(42,7,16,.55) 0%, rgba(6,4,10,.92) 75%),
      linear-gradient(180deg, rgba(6,4,10,.6) 0%, rgba(6,4,10,.3) 40%, rgba(6,4,10,.85) 100%);}
  .portada-vignette{position:absolute;inset:0;
    background:radial-gradient(ellipse at center, transparent 30%, rgba(6,4,10,.95) 100%);}
  /* canvas para los bongos visuales en la portada */
  #portada-canvas{position:absolute;inset:0;z-index:1;pointer-events:none;}

  .portada-content{position:relative;z-index:2;
    height:100%;display:flex;flex-direction:column;
    align-items:center;justify-content:center;
    padding:8vw 6vw;text-align:center;}

  /* marca arriba */
  .marca{position:relative;text-align:center;
    font-family:var(--sans);font-size:13px;letter-spacing:.7em;
    text-transform:uppercase;color:var(--hueso);font-weight:600;
    padding-left:.7em;margin-bottom:1.8em;
    opacity:0;animation:fade-in 1.2s .3s ease forwards;}

  /* "presents" */
  .presents{font-family:var(--sans);font-size:10px;
    letter-spacing:.5em;text-transform:uppercase;
    color:var(--tinta);margin-bottom:2.4em;font-weight:400;
    padding-left:.5em;
    opacity:0;animation:fade-in 1.2s .8s ease forwards;}

  /* TITULO grande */
  .titulo{font-family:var(--serif);
    font-size:clamp(54px,11vw,150px);
    line-height:.92;color:var(--hueso);
    font-weight:300;letter-spacing:-.015em;
    text-shadow:0 0 80px rgba(168,18,26,.5),
                0 0 30px rgba(0,0,0,.8);
    max-width:90vw;
    opacity:0;animation:fade-in 1.4s 1.1s ease forwards;}
  .titulo .lin1{display:block;}
  .titulo .lin2{display:block;font-style:italic;
    color:var(--sangre);font-weight:400;
    animation:pulse-sangre 3.2s ease-in-out infinite;}
  @keyframes pulse-sangre{
    0%, 100%{
      color:var(--sangre);
      text-shadow:0 0 80px rgba(168,18,26,.4), 0 0 30px rgba(0,0,0,.8);
    }
    50%{
      color:var(--sangre-bright);
      text-shadow:0 0 120px rgba(214,40,40,.7), 0 0 50px rgba(168,18,26,.5);
    }
  }

  /* subtitulo */
  .subtitulo{font-family:var(--sans);font-size:11px;
    letter-spacing:.45em;text-transform:uppercase;
    color:var(--tinta);margin-top:1.6em;font-weight:400;
    padding-left:.45em;
    opacity:0;animation:fade-in 1.2s 1.6s ease forwards;}

  /* invitación a tocar */
  .invitacion{font-family:var(--serif);font-style:italic;
    font-size:clamp(17px,2.4vw,22px);
    line-height:1.7;color:rgba(240,232,220,.78);
    margin-top:2.6em;max-width:520px;font-weight:300;
    letter-spacing:.005em;
    opacity:0;animation:fade-in 1.4s 2s ease forwards;}
  .invitacion strong{font-style:normal;font-weight:400;
    color:var(--hueso);}
  .invitacion .toca{color:var(--sangre);font-style:italic;font-weight:400;
    border-bottom:1px solid rgba(168,18,26,.4);padding-bottom:.05em;}

  /* hint chico debajo */
  .hint{font-family:var(--sans);font-size:10px;
    letter-spacing:.35em;text-transform:uppercase;
    color:rgba(138,132,124,.7);margin-top:1.4em;font-weight:400;
    padding-left:.35em;
    opacity:0;animation:fade-in-pulse 2.4s 2.6s ease forwards;}
  @keyframes fade-in-pulse{
    0%{opacity:0;}
    40%{opacity:.95;}
    100%{opacity:.6;}
  }

  /* BOTON con borde animado */
  .iniciar-wrap{position:relative;margin-top:3.2em;
    opacity:0;animation:fade-in 1.4s 2.2s ease forwards;
    border-radius:999px;
    padding:1px;
    overflow:hidden;}
  .iniciar-wrap::before{content:'';position:absolute;
    inset:-50%;
    background:conic-gradient(
      from 0deg,
      transparent 0deg,
      transparent 200deg,
      rgba(168,18,26,.7) 270deg,
      rgba(214,40,40,1) 310deg,
      rgba(168,18,26,.7) 350deg,
      transparent 360deg);
    animation:spin-border 4.5s linear infinite;}
  .iniciar{position:relative;background:var(--vacio);
    cursor:pointer;border:none;
    color:var(--hueso);
    font-family:var(--sans);
    font-size:clamp(11px,1.7vw,13px);
    letter-spacing:.32em;text-transform:uppercase;
    padding:1.15em 2.6em;
    border-radius:999px;
    font-weight:500;
    transition:background .4s ease;
    -webkit-appearance:none;appearance:none;
    display:block;}
  .iniciar:hover{background:var(--vino-oscuro);}
  @keyframes spin-border{
    to{transform:rotate(360deg);}
  }

  /* pie inferior */
  .pie{position:absolute;bottom:4vh;left:0;right:0;
    font-family:var(--sans);font-size:9px;
    letter-spacing:.4em;text-transform:uppercase;
    color:var(--tinta);line-height:2;font-weight:400;
    text-align:center;
    display:flex;flex-direction:column;align-items:center;gap:.4em;
    opacity:0;animation:fade-in 1.4s 2.8s ease forwards;}
  .pie .firma{font-family:var(--serif);font-style:italic;
    font-size:13px;letter-spacing:.06em;
    color:rgba(168,18,26,.75);text-transform:none;}

  @keyframes fade-in{
    from{opacity:0;transform:translateY(8px);}
    to{opacity:1;transform:translateY(0);}
  }

  /* ============================================
     EXPERIENCE — editorial layout
     ============================================ */
  #altar{position:fixed;z-index:5;left:50%;top:38%;
    transform:translate(-50%,-50%);
    width:clamp(170px,28vmin,320px);
    aspect-ratio:1/1;
    opacity:0;transition:opacity 2s ease;
    pointer-events:none;will-change:transform,filter;}
  #altar.dentro{opacity:1;}
  #altar img{width:100%;height:100%;object-fit:cover;
    display:block;border-radius:2px;
    box-shadow:
      0 0 80px rgba(168,18,26,.35),
      0 0 160px rgba(90,14,28,.25),
      0 0 0 1px rgba(168,18,26,.15);
    filter:contrast(1.05) saturate(.9);
    pointer-events:none;-webkit-user-drag:none;}

  #halo{position:fixed;z-index:4;left:50%;top:38%;
    transform:translate(-50%,-50%);
    width:clamp(260px,48vmin,560px);
    aspect-ratio:1/1;
    opacity:0;transition:opacity 2s ease;
    pointer-events:none;
    background:radial-gradient(circle, rgba(168,18,26,.22) 0%, rgba(90,14,28,.1) 40%, transparent 70%);
    filter:blur(24px);will-change:transform,opacity;}
  #halo.dentro{opacity:1;}

  /* HUD */
  #hud{position:fixed;z-index:20;inset:0;pointer-events:none;
    opacity:0;transition:opacity 1.8s ease;}
  #hud.dentro{opacity:1;}

  /* TÍTULO arriba del cover, centrado */
  .titulo-arriba{position:fixed;left:50%;
    top:calc(38% - clamp(150px,22vmin,240px));
    transform:translateX(-50%);
    text-align:center;width:90vw;}
  .titulo-arriba .t1{display:block;
    font-family:var(--serif);
    font-size:clamp(34px,6vw,68px);
    line-height:1;color:var(--hueso);
    font-weight:300;letter-spacing:-.005em;
    text-shadow:0 0 40px rgba(0,0,0,.7);}
  .titulo-arriba .t1 em{font-style:italic;color:var(--sangre);
    font-weight:400;animation:pulse-sangre 3.2s ease-in-out infinite;}
  .titulo-arriba .ome{display:block;
    font-family:var(--sans);font-size:clamp(13px,1.4vw,16px);
    letter-spacing:.55em;text-transform:uppercase;
    color:var(--hueso);margin-top:1.2em;font-weight:600;
    padding-left:.55em;}

  /* Ōme top-left */
  .marca-hud{position:absolute;top:4vw;left:4vw;
    font-family:var(--sans);font-size:11px;
    letter-spacing:.55em;text-transform:uppercase;
    color:var(--hueso);font-weight:600;padding-left:.55em;letter-spacing:.6em;}

  /* Vol */
  .vol{position:absolute;top:4vw;right:4vw;pointer-events:auto;
    display:none;align-items:center;gap:.7em;}
  .vol input{-webkit-appearance:none;appearance:none;
    width:80px;height:1px;
    background:var(--vino);outline:none;}
  .vol input::-webkit-slider-thumb{-webkit-appearance:none;
    width:11px;height:11px;border-radius:50%;
    background:var(--sangre);cursor:pointer;}
  .vol input::-moz-range-thumb{width:11px;height:11px;border:none;
    border-radius:50%;background:var(--sangre);cursor:pointer;}
  .vol span{font-family:var(--sans);font-size:9px;
    letter-spacing:.35em;color:var(--tinta);font-weight:400;
    padding-left:.35em;}

  /* CRÉDITOS — debajo del cover, centrados */
  .creditos{position:fixed;left:50%;
    top:calc(38% + clamp(115px,18vmin,180px));
    transform:translateX(-50%);
    text-align:center;width:90vw;max-width:560px;
    display:flex;flex-direction:column;gap:.05em;}
  .cr-row{font-family:var(--sans);font-size:clamp(10px,1vw,11.5px);
    letter-spacing:.32em;text-transform:uppercase;
    color:rgba(240,232,220,.85);
    line-height:1.85;font-weight:400;letter-spacing:.18em;}
  .cr-row strong{color:rgba(168,18,26,.85);font-weight:500;letter-spacing:.22em;}
  .cr-row .val{color:var(--hueso);font-weight:400;}

  /* hint flotante */
  .pista-nota{position:fixed;left:50%;
    top:calc(38% - clamp(220px,32vmin,340px));
    transform:translateX(-50%);
    font-family:var(--serif);font-style:italic;
    font-size:clamp(11px,1.3vw,13px);
    letter-spacing:.18em;color:rgba(200,196,190,.55);
    text-align:center;opacity:0;
    transition:opacity 1.6s ease;pointer-events:none;
    font-weight:400;max-width:80vw;
    text-transform:uppercase;}
  .pista-nota.aparece{opacity:1;}

  /* REDES — 2 columnas centradas abajo */
  .redes{position:fixed;bottom:4vw;left:50%;
    transform:translateX(-50%);
    display:grid;grid-template-columns:1fr 1fr;
    gap:1em;pointer-events:auto;
    width:min(540px, 90vw);}
  .red{font-family:var(--sans);
    font-size:10px;letter-spacing:.32em;
    text-transform:uppercase;color:var(--hueso);
    text-decoration:none;font-weight:400;
    border:1px solid rgba(90,14,28,.55);
    padding:1.1em 1.4em;border-radius:999px;
    transition:all .4s ease;
    background:rgba(6,4,10,.55);
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
    text-align:center;
    display:flex;align-items:center;justify-content:center;
    gap:.6em;
    padding-left:calc(1.4em + .32em);}
  .red:hover{background:rgba(90,14,28,.7);
    border-color:var(--sangre);
    box-shadow:0 0 40px rgba(168,18,26,.35);}
  .red em{font-style:italic;color:var(--sangre);
    text-transform:none;letter-spacing:.02em;
    font-family:var(--serif);font-weight:500;font-size:14px;
    padding-left:0;}

  #humo-arriba{position:fixed;inset:0;z-index:10;pointer-events:none;
    mix-blend-mode:screen;}

  /* RESPONSIVE */
  @media (max-width:700px){
    .marca{font-size:10px;letter-spacing:.5em;}
    .invitacion{font-size:16px;}
    .titulo-arriba{top:calc(38% - clamp(140px,30vmin,200px));}
    .titulo-arriba .t1{font-size:clamp(28px,7vw,42px);}
    .titulo-arriba .ome{font-size:10px;letter-spacing:.45em;margin-top:.8em;}
    .marca-hud{display:none;}
    .creditos{top:calc(38% + clamp(105px,24vmin,150px));}
    .cr-row{font-size:9px;letter-spacing:.22em;line-height:2;}
    .redes{grid-template-columns:1fr;gap:.5em;
      width:min(360px,80vw);bottom:5vw;}
    .red{font-size:10px;padding:1em 1.4em;}
    .pista-nota{top:calc(38% - clamp(190px,40vmin,240px));font-size:10px;letter-spacing:.14em;}
  }

  @supports (padding: env(safe-area-inset-top)){
    .portada-content{
      padding-top:max(8vw, env(safe-area-inset-top));
      padding-bottom:max(8vw, env(safe-area-inset-bottom));
    }
    .pie{bottom:max(4vh, env(safe-area-inset-bottom));}
    .redes{bottom:max(4vw, calc(env(safe-area-inset-bottom) + 1vw));}
  }
</style>
</head>
<body>

<canvas id="lienzo"></canvas>
<div id="halo"></div>
<div id="altar"><img src="/audio/paywalldesangre-cover.png" alt="Paywall de Sangre" draggable="false"></div>
<canvas id="humo-arriba"></canvas>

<!-- HUD durante experiencia -->
<div id="hud">
  <div class="marca-hud">Ōme</div>
  <div class="vol">
    <span>VOL</span>
    <input type="range" id="vol" min="0" max="1" step="0.01" value="0.85">
  </div>

  <div class="titulo-arriba">
    <span class="t1">Paywall <em>de Sangre</em></span>
    <span class="ome">Ōme</span>
  </div>

  <div class="creditos">
    <div class="cr-row"><strong>Track</strong> · <span class="val">Paywall de Sangre</span></div>
    <div class="cr-row"><strong>Composed &amp; produced by</strong> · <span class="val">César Del Pino (2026)</span></div>
    <div class="cr-row"><strong>Female vocals</strong> · <span class="val">Fernanda Viera, Robert T.</span></div>
    <div class="cr-row"><strong>Percussion</strong> · <span class="val">José Ramírez</span></div>
    <div class="cr-row"><strong>Mix &amp; mastering</strong> · <span class="val">Acupuncture Studio</span></div>
    <div class="cr-row"><strong>Project</strong> · <span class="val">Ōme</span></div>
  </div>

  <div class="pista-nota" id="pista-nota">drag the smoke · tap to play with me</div>

  <div class="redes">
    <a class="red" href="https://soundcloud.com/omemusic/paywall-sangre" target="_blank" rel="noopener">
      Listen on <em>SoundCloud</em>
    </a>
    <a class="red" href="https://instagram.com/omemusicmx" target="_blank" rel="noopener">
      Follow on <em>Instagram</em>
    </a>
  </div>
</div>

<!-- PORTADA -->
<div id="portada">
  <div class="portada-bg"></div>
  <div class="portada-overlay"></div>
  <div class="portada-vignette"></div>
  <canvas id="portada-canvas"></canvas>

  <div class="portada-content">
    <div class="marca">Ōme</div>
    <div class="presents">presents</div>

    <h1 class="titulo">
      <span class="lin1">Paywall</span>
      <span class="lin2">de Sangre</span>
    </h1>

    <div class="subtitulo">an interactive sonic ritual</div>

    <p class="invitacion">
      Welcome to the sonic experience of my latest release.<br>
      <strong>Tap the screen</strong> — two bongos rest in your hands.<br>
      <span class="toca">Play with me</span>, weave your rhythm into mine.
    </p>

    <div class="hint">tap anywhere · feel the drums</div>

    <div class="iniciar-wrap">
      <button class="iniciar" id="btn" type="button">Begin experience · I authorize audio playback</button>
    </div>

    <div class="pie">
      7 min · use headphones
      <span class="firma">an experience by César Del Pino</span>
    </div>
  </div>
</div>

<audio id="audio" preload="auto" crossorigin="anonymous" playsinline webkit-playsinline>
  <source src="/audio/paywalldesangre.mp3" type="audio/mpeg">
</audio>
<audio id="bongoA" preload="auto" playsinline webkit-playsinline>
  <source src="/audio/bongo-a.mp3" type="audio/mpeg">
</audio>
<audio id="bongoB" preload="auto" playsinline webkit-playsinline>
  <source src="/audio/bongo-b.mp3" type="audio/mpeg">
</audio>

<script>
/* =========================================================
   PAYWALL DE SANGRE v4
   ========================================================= */

let ctx, analizador, datos, fuente, ganancia;
let bongoBufferA = null, bongoBufferB = null;
let alternar = 0;
let audioYaIniciado = false;
const audioEl = document.getElementById('audio');
const bongoElA = document.getElementById('bongoA');
const bongoElB = document.getElementById('bongoB');

async function precargarBongos(){
  if(!ctx) return;
  try{
    const cargarBuffer = async (url)=>{
      const r = await fetch(url);
      const ab = await r.arrayBuffer();
      return await ctx.decodeAudioData(ab);
    };
    bongoBufferA = await cargarBuffer('/audio/bongo-a.mp3');
    bongoBufferB = await cargarBuffer('/audio/bongo-b.mp3');
  }catch(e){
    console.warn('bongos via fetch falló, fallback HTMLAudio:', e);
  }
}

/* AudioContext sin track principal, sólo para bongos antes de "Begin" */
function arrancarContextoBongos(){
  if(ctx) return;
  ctx = new (window.AudioContext||window.webkitAudioContext)();
  if(ctx.state === 'suspended') ctx.resume();
  precargarBongos();
}

/* Cuando hace click en "Begin", conectamos el track al ctx existente */
function arrancarTrack(){
  if(audioYaIniciado) return;
  if(!ctx) arrancarContextoBongos();
  fuente = ctx.createMediaElementSource(audioEl);
  ganancia = ctx.createGain();
  ganancia.gain.value = parseFloat(document.getElementById('vol').value || 0.85);
  analizador = ctx.createAnalyser();
  analizador.fftSize = 1024;
  datos = new Uint8Array(analizador.frequencyBinCount);
  fuente.connect(ganancia);
  ganancia.connect(analizador);
  analizador.connect(ctx.destination);
  const p = audioEl.play();
  if(p && p.catch) p.catch(e=>console.warn('audio:',e));
  audioYaIniciado = true;
}

function tocarBongo(){
  const usarA = (alternar % 2) === 0;
  alternar++;
  if(ctx && (usarA ? bongoBufferA : bongoBufferB)){
    const src = ctx.createBufferSource();
    src.buffer = usarA ? bongoBufferA : bongoBufferB;
    const g = ctx.createGain();
    g.gain.value = 0.9;
    src.connect(g);
    g.connect(ctx.destination);
    src.start(0);
  }else{
    const el = usarA ? bongoElA : bongoElB;
    try{ el.currentTime = 0; el.play().catch(()=>{}); }catch(e){}
  }
}

function leerAudio(){
  if(!analizador) return {grave:0,medio:0,agudo:0,kick:0};
  analizador.getByteFrequencyData(datos);
  let g=0,m=0,a=0,k=0;
  const n=datos.length;
  const c1=Math.floor(n*.08), c2=Math.floor(n*.35);
  for(let i=0;i<4;i++) k=Math.max(k,datos[i]);
  for(let i=0;i<c1;i++) g+=datos[i];
  for(let i=c1;i<c2;i++) m+=datos[i];
  for(let i=c2;i<n;i++) a+=datos[i];
  return {grave:g/(c1*255), medio:m/((c2-c1)*255),
    agudo:a/((n-c2)*255), kick:k/255};
}

/* ---------- PORTADA CANVAS — pulsos al tocar antes de entrar ---------- */
const portadaCanvas = document.getElementById('portada-canvas');
const pcx = portadaCanvas.getContext('2d');
let pW, pH;
let pulsos = [];

function medirPortada(){
  pW = portadaCanvas.width = innerWidth * (devicePixelRatio||1);
  pH = portadaCanvas.height = innerHeight * (devicePixelRatio||1);
  portadaCanvas.style.width = innerWidth+'px';
  portadaCanvas.style.height = innerHeight+'px';
}
medirPortada();
addEventListener('resize', medirPortada);

function portadaTap(e){
  // ignorar si toca el botón
  if(e.target && (e.target.closest('.iniciar-wrap'))) return;
  arrancarContextoBongos();
  tocarBongo();
  const t = (e.touches && e.touches[0]) || e;
  const dpr = devicePixelRatio||1;
  pulsos.push({
    x:t.clientX*dpr, y:t.clientY*dpr,
    r:10*dpr, max:Math.min(pW,pH)*0.4,
    op:0.7
  });
  if(pulsos.length > 30) pulsos.shift();
}
document.getElementById('portada').addEventListener('click', portadaTap);
document.getElementById('portada').addEventListener('touchstart', e=>{
  if(e.target && e.target.closest('.iniciar-wrap')) return;
  e.preventDefault();
  portadaTap(e);
}, {passive:false});

function dibujarPortada(){
  if(document.getElementById('portada').classList.contains('fuera')) return;
  requestAnimationFrame(dibujarPortada);
  pcx.clearRect(0,0,pW,pH);
  for(let i=pulsos.length-1;i>=0;i--){
    const p = pulsos[i];
    p.r += 4*(devicePixelRatio||1);
    p.op *= 0.97;
    if(p.r > p.max || p.op < 0.02){ pulsos.splice(i,1); continue; }
    pcx.strokeStyle = `hsla(355 80% 50% / ${p.op})`;
    pcx.lineWidth = 1.5*(devicePixelRatio||1);
    pcx.beginPath();
    pcx.arc(p.x, p.y, p.r, 0, 6.28);
    pcx.stroke();
    // inner glow
    pcx.fillStyle = `hsla(355 85% 45% / ${p.op*0.08})`;
    pcx.beginPath();
    pcx.arc(p.x, p.y, p.r*0.6, 0, 6.28);
    pcx.fill();
  }
}
dibujarPortada();

/* ---------- CANVAS EXPERIENCIA ---------- */
const lienzo = document.getElementById('lienzo');
const cx = lienzo.getContext('2d');
const humoArriba = document.getElementById('humo-arriba');
const cxArriba = humoArriba.getContext('2d');
let W,H,DPR;

function medir(){
  DPR = Math.min(devicePixelRatio||1, 2);
  W = lienzo.width = humoArriba.width = innerWidth*DPR;
  H = lienzo.height = humoArriba.height = innerHeight*DPR;
  lienzo.style.width = humoArriba.style.width = innerWidth+'px';
  lienzo.style.height = humoArriba.style.height = innerHeight+'px';
}
addEventListener('resize', medir); medir();

const esMovil = innerWidth < 700;
const PART_FONDO = esMovil ? 110 : 180;
const PART_FRENTE = esMovil ? 45 : 70;
let particulasFondo = [];
let particulasFrente = [];
let manchas = [];
let raton = {x:W/2, y:H/2, activo:false, vx:0, vy:0, px:W/2, py:H/2};
let suaveG=0, suaveM=0, suaveA=0, suaveK=0, pulso=0, pulsoUlt=0;
let experienciaActiva = false;

function nuevaParticula(esFrente=false){
  const ang = Math.random()*Math.PI*2;
  const rad = Math.random()*Math.min(W,H)*0.7 + Math.min(W,H)*0.05;
  return {
    x: W/2 + Math.cos(ang)*rad,
    y: H/2 + Math.sin(ang)*rad,
    vx:(Math.random()-0.5)*0.8,
    vy:(Math.random()-0.5)*0.8 - 0.3,
    r: esFrente ? (50+Math.random()*90)*DPR : (90+Math.random()*180)*DPR,
    vida: Math.random(),
    vidaMax: 0.9+Math.random()*0.7,
    tono: 350+Math.random()*15,
    sat: 55+Math.random()*30,
    lum: 10+Math.random()*18,
    esFrente
  };
}
for(let i=0;i<PART_FONDO;i++) particulasFondo.push(nuevaParticula(false));
for(let i=0;i<PART_FRENTE;i++) particulasFrente.push(nuevaParticula(true));

function pos(e){
  const t = (e.touches && e.touches.length) ? e.touches[0] :
            (e.changedTouches && e.changedTouches.length) ? e.changedTouches[0] : e;
  return {x:t.clientX*DPR, y:t.clientY*DPR};
}
function mover(e){
  if(!experienciaActiva) return;
  if(e.cancelable && e.touches) e.preventDefault();
  const p = pos(e);
  raton.vx = p.x-raton.px; raton.vy = p.y-raton.py;
  raton.px = p.x; raton.py = p.y;
  raton.x = p.x; raton.y = p.y; raton.activo = true;

  const radio = Math.min(W,H)*0.22;
  const fuerzaMax = 0.22;
  const procesar = (arr)=>{
    for(const par of arr){
      const dx = par.x-p.x, dy = par.y-p.y;
      const d = Math.hypot(dx,dy);
      if(d < radio){
        const f = (1 - d/radio) * fuerzaMax;
        par.vx += raton.vx * f * 0.1;
        par.vy += raton.vy * f * 0.1;
        const ang = Math.atan2(dy,dx);
        par.vx += Math.cos(ang)*f*0.5;
        par.vy += Math.sin(ang)*f*0.5;
        par.vida = Math.min(par.vidaMax, par.vida+f*0.5);
      }
    }
  };
  procesar(particulasFondo);
  procesar(particulasFrente);
}
function manchar(e){
  if(!experienciaActiva) return;
  if(e.cancelable && e.touches) e.preventDefault();
  const p = pos(e);
  tocarBongo();
  manchas.push({x:p.x, y:p.y, r:22+Math.random()*26, op:0.75, edad:0});
  if(manchas.length > 50) manchas.shift();
  for(let i=0;i<12;i++){
    const ang=Math.random()*Math.PI*2;
    const v=2+Math.random()*5;
    particulasFrente.push({
      x:p.x, y:p.y,
      vx:Math.cos(ang)*v, vy:Math.sin(ang)*v - 1.2,
      r:(40+Math.random()*50)*DPR,
      vida:1, vidaMax:1,
      tono:355, sat:78, lum:22+Math.random()*12,
      esFrente:true
    });
  }
  if(particulasFrente.length > 120) particulasFrente.splice(0, particulasFrente.length-120);
}

addEventListener('mousemove', mover);
addEventListener('mousedown', e=>{
  if(e.target && e.target.closest('a, button, .vol, .red, .redes')) return;
  manchar(e); mover(e);
});
addEventListener('touchmove', mover, {passive:false});
addEventListener('touchstart', e=>{
  if(!experienciaActiva) return;
  if(e.target && e.target.closest('a, button, .vol, .red, .redes')) return;
  manchar(e); mover(e);
}, {passive:false});

const altar = document.getElementById('altar');
const halo = document.getElementById('halo');

function dibujar(){
  requestAnimationFrame(dibujar);
  if(!experienciaActiva){
    cx.clearRect(0,0,W,H);
    cxArriba.clearRect(0,0,W,H);
    return;
  }
  const a = leerAudio();
  suaveG += (a.grave-suaveG)*0.12;
  suaveM += (a.medio-suaveM)*0.18;
  suaveA += (a.agudo-suaveA)*0.25;
  suaveK += (a.kick-suaveK)*0.45;

  if(a.kick > 0.55 && a.kick > pulsoUlt) pulso = 1;
  pulsoUlt = a.kick;
  pulso *= 0.85;

  cx.fillStyle = `rgba(6,4,10,${0.08 + pulso*0.03})`;
  cx.fillRect(0,0,W,H);
  cxArriba.clearRect(0,0,W,H);

  if(suaveG > 0.1){
    cx.fillStyle = `rgba(90,14,28,${suaveG*0.035})`;
    cx.fillRect(0,0,W,H);
  }

  const escala = 1 + pulso*0.04 + suaveG*0.02;
  altar.style.transform = `translate(-50%,-50%) scale(${escala})`;
  altar.style.filter = `contrast(${1.05+pulso*0.1}) saturate(${0.9+suaveK*0.3}) brightness(${1+pulso*0.15})`;
  halo.style.transform = `translate(-50%,-50%) scale(${1 + pulso*0.18 + suaveG*0.1})`;
  halo.style.opacity = 0.75 + suaveG*0.3 + pulso*0.2;

  const dibujarParticulas = (arr, contexto)=>{
    for(let i=arr.length-1;i>=0;i--){
      const p = arr[i];
      p.x += p.vx*(1+suaveK*0.3);
      p.y += p.vy*(1+suaveK*0.3);
      p.vy -= 0.01;
      p.vx *= 0.985; p.vy *= 0.985;
      p.vida -= 0.0025;
      if(p.vida <= 0 || p.x < -300 || p.x > W+300 || p.y < -400){
        arr[i] = nuevaParticula(p.esFrente);
        continue;
      }
      const radioEf = p.r * (1 + suaveG*0.6 + pulso*0.35);
      const op = p.vida * (0.22 + suaveM*0.14 + pulso*0.1);
      const grad = contexto.createRadialGradient(p.x, p.y, 0, p.x, p.y, radioEf);
      grad.addColorStop(0, `hsla(${p.tono} ${p.sat}% ${p.lum + pulso*18}% / ${op})`);
      grad.addColorStop(0.5, `hsla(${p.tono-5} ${p.sat-15}% ${p.lum*0.7}% / ${op*0.5})`);
      grad.addColorStop(1, `hsla(${p.tono} 50% 5% / 0)`);
      contexto.fillStyle = grad;
      contexto.beginPath();
      contexto.arc(p.x, p.y, radioEf, 0, 6.28);
      contexto.fill();
    }
  };

  dibujarParticulas(particulasFondo, cx);
  dibujarParticulas(particulasFrente, cxArriba);

  for(let i=manchas.length-1;i>=0;i--){
    const m = manchas[i];
    m.edad += 0.01;
    if(m.edad > 1){ manchas.splice(i,1); continue; }
    const rad = m.r * (1 + m.edad*2.5) * DPR;
    const op = m.op * (1 - m.edad);
    const grad = cxArriba.createRadialGradient(m.x, m.y, 0, m.x, m.y, rad);
    grad.addColorStop(0, `hsla(355 80% 38% / ${op})`);
    grad.addColorStop(0.4, `hsla(350 65% 22% / ${op*0.6})`);
    grad.addColorStop(1, 'hsla(350 50% 8% / 0)');
    cxArriba.fillStyle = grad;
    cxArriba.beginPath();
    cxArriba.arc(m.x, m.y, rad, 0, 6.28);
    cxArriba.fill();
  }

  if(raton.activo){
    const vel = Math.hypot(raton.vx, raton.vy);
    if(vel > 1){
      const radEst = (14 + vel*0.7)*DPR;
      const grad = cxArriba.createRadialGradient(raton.x, raton.y, 0, raton.x, raton.y, radEst);
      grad.addColorStop(0, `hsla(355 85% 50% / ${Math.min(0.55, vel/50)})`);
      grad.addColorStop(1, 'hsla(355 70% 20% / 0)');
      cxArriba.fillStyle = grad;
      cxArriba.beginPath();
      cxArriba.arc(raton.x, raton.y, radEst, 0, 6.28);
      cxArriba.fill();
    }
  }
  raton.vx *= 0.85; raton.vy *= 0.85;
}
dibujar();

function entrar(){
  arrancarTrack();
  experienciaActiva = true;
  document.getElementById('portada').classList.add('fuera');
  document.getElementById('hud').classList.add('dentro');
  altar.classList.add('dentro');
  halo.classList.add('dentro');
  setTimeout(()=>{
    document.getElementById('pista-nota').classList.add('aparece');
    setTimeout(()=>{
      document.getElementById('pista-nota').style.opacity = '.35';
    }, 8000);
  }, 2000);
}

const btn = document.getElementById('btn');
btn.addEventListener('click', entrar);
btn.addEventListener('touchend', e=>{e.preventDefault(); entrar();}, {passive:false});

document.getElementById('vol').addEventListener('input', e=>{
  if(ganancia) ganancia.gain.value = parseFloat(e.target.value);
});

audioEl.addEventListener('ended', ()=>{
  document.getElementById('pista-nota').textContent = 'the transmission ends · the smoke remains';
  document.getElementById('pista-nota').classList.add('aparece');
});
</script>
</body>
</html>
