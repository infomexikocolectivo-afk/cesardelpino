---
// Header.astro - Navegación fija arriba, presente en todas las páginas
export interface Props {
  lang?: 'es' | 'en';
  currentPath?: string;
}

const { lang = 'es', currentPath = '/' } = Astro.props;

const labels = {
  es: { obra: 'Obra', estudio: 'Estudio', ome: 'Ōme', bitacora: 'Bitácora', contacto: 'Contacto' },
  en: { obra: 'Works', estudio: 'Studio', ome: 'Ōme', bitacora: 'Journal', contacto: 'Contact' },
};
const t = labels[lang];

const langPrefix = lang === 'en' ? '/en' : '';
---

<header class="site-header">
  <a href={`${langPrefix}/`} class="brand-mark">César <em>Del</em> Pino</a>

  <div class="nav-cluster">
    <ul class="main-nav">
      <li><a href={`${langPrefix}/#works`}>{t.obra}</a></li>
      <li><a href={`${langPrefix}/#studio`}>{t.estudio}</a></li>
      <li><a href={`${langPrefix}/ome/`}>{t.ome}</a></li>
      <li><a href={`${langPrefix}/bitacora/`}>{t.bitacora}</a></li>
      <li><a href={`${langPrefix}/contacto/`}>{t.contacto}</a></li>
    </ul>

    <div class="lang-toggle">
      <a href={currentPath.replace('/en', '') || '/'} class={lang === 'es' ? 'active' : ''}>ES</a>
      <span class="sep">/</span>
      <a href={'/en' + currentPath.replace('/en', '')} class={lang === 'en' ? 'active' : ''}>EN</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 28px 56px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(237, 232, 221, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-line);
  }

  .brand-mark {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }

  .brand-mark em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent-gold);
  }

  .nav-cluster {
    display: flex;
    align-items: center;
    gap: 48px;
  }

  .main-nav {
    display: flex;
    list-style: none;
    gap: 36px;
  }

  .main-nav a {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-primary);
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .main-nav a:hover { color: var(--accent-blood); }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    border-left: 1px solid var(--border-line);
    padding-left: 24px;
  }

  .lang-toggle a { color: var(--text-muted); transition: color 0.2s ease; }
  .lang-toggle a.active { color: var(--text-primary); }
  .lang-toggle a:hover { color: var(--accent-blood); }
  .lang-toggle .sep { color: var(--text-subtle); }

  @media (max-width: 700px) {
    .site-header { padding: 20px 24px; }
    .main-nav { display: none; }
  }
</style>
