---
export interface Props {
  lang?: 'es' | 'en';
  currentPath?: string;
}

const { lang = 'es', currentPath = '/' } = Astro.props;

const labels = {
  es: { obra: 'Obra', estudio: 'Estudio', ome: 'Ōme', bitacora: 'Bitácora', contacto: 'Contacto' },
  en: { obra: 'Works', estudio: 'Studio', ome: 'Ōme', bitacora: 'Journal', contacto: 'Contact' },
};

const t = labels[lang];
const langPrefix = lang === 'en' ? '/en' : '';
---

<header class="site-header">
  <a href={`${langPrefix}/`} class="brand-mark">César <em>Del</em> Pino</a>

  <div class="nav-cluster">
    <ul class="main-nav">
      <li><a href={`${langPrefix}/#works`}>{t.obra}</a></li>
      <li><a href={`${langPrefix}/#studio`}>{t.estudio}</a></li>
      <li><a href={`${langPrefix}/ome/`}>{t.ome}</a></li>
      <li><a href={`${langPrefix}/bitacora/`}>{t.bitacora}</a></li>
      <li><a href={`${langPrefix}/contacto/`}>{t.contacto}</a></li>
    </ul>
    <div class="lang-toggle">
      <a href={currentPath.replace('/en', '') || '/'} class={lang === 'es' ? 'active' : ''}>ES</a>
      <span class="sep">/</span>
      <a href={'/en' + currentPath.replace('/en', '')} class={lang === 'en' ? 'active' : ''}>EN</a>
    </div>
  </div>

  <button class="mobile-toggle" aria-label="Abrir menú" aria-expanded="false" id="mobile-toggle">
    <span class="burger-top"></span>
    <span class="burger-btm"></span>
  </button>
</header>

<!-- Mobile menu — slides from right, full screen -->
<nav class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <div class="mobile-inner">

    <ul class="mobile-nav">
      <li style="--i:0">
        <a href={`${langPrefix}/#works`} class="mobile-link">
          <span class="link-name">{t.obra}</span>
          <span class="link-num">01</span>
        </a>
      </li>
      <li style="--i:1">
        <a href={`${langPrefix}/#studio`} class="mobile-link">
          <span class="link-name">{t.estudio}</span>
          <span class="link-num">02</span>
        </a>
      </li>
      <li style="--i:2">
        <a href={`${langPrefix}/ome/`} class="mobile-link">
          <span class="link-name">{t.ome}</span>
          <span class="link-num">03</span>
        </a>
      </li>
      <li style="--i:3">
        <a href={`${langPrefix}/bitacora/`} class="mobile-link">
          <span class="link-name">{t.bitacora}</span>
          <span class="link-num">04</span>
        </a>
      </li>
      <li style="--i:4">
        <a href={`${langPrefix}/contacto/`} class="mobile-link">
          <span class="link-name">{t.contacto}</span>
          <span class="link-num">05</span>
        </a>
      </li>
    </ul>

    <div class="mobile-footer">
      <div class="mobile-lang">
        <a href={currentPath.replace('/en', '') || '/'} class={lang === 'es' ? 'active' : ''}>ES</a>
        <span class="sep">/</span>
        <a href={'/en' + currentPath.replace('/en', '')} class={lang === 'en' ? 'active' : ''}>EN</a>
      </div>
      <span class="mobile-tagline">Sonic Anthropologist</span>
    </div>

  </div>
</nav>

<style>
  /* HEADER */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
    height: 72px;
    padding: 0 56px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(237, 232, 221, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-line);
  }

  .brand-mark {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    position: relative;
    z-index: 301;
    font-variation-settings: "opsz" 144, "SOFT" 30;
  }

  .brand-mark em {
    font-style: italic;
    font-weight: 500;
    color: var(--accent-gold);
    font-variation-settings: "opsz" 144, "SOFT" 100;
  }

  /* DESKTOP NAV */
  .nav-cluster {
    display: flex;
    align-items: center;
    gap: 48px;
  }

  .main-nav {
    display: flex;
    list-style: none;
    gap: 36px;
  }

  .main-nav a {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-primary);
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .main-nav a:hover { color: var(--accent-blood); }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    border-left: 1px solid var(--border-line);
    padding-left: 24px;
  }

  .lang-toggle a { color: var(--text-muted); transition: color 0.2s ease; }
  .lang-toggle a.active { color: var(--text-primary); }
  .lang-toggle a:hover { color: var(--accent-blood); }
  .lang-toggle .sep { color: var(--text-subtle); }

  /* HAMBURGER BUTTON */
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    width: 40px;
    height: 40px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    gap: 7px;
    position: relative;
    z-index: 301;
  }

  .burger-top,
  .burger-btm {
    display: block;
    height: 1px;
    background: var(--text-primary);
    transition:
      transform 0.4s cubic-bezier(0.76, 0, 0.24, 1),
      width 0.3s ease;
    transform-origin: center;
  }

  .burger-top { width: 24px; }
  .burger-btm { width: 16px; } /* asymmetry editorial */

  .mobile-toggle[aria-expanded="true"] .burger-top {
    transform: translateY(4px) rotate(45deg);
    width: 22px;
  }
  .mobile-toggle[aria-expanded="true"] .burger-btm {
    transform: translateY(-3px) rotate(-45deg);
    width: 22px;
  }

  /* MOBILE MENU — slide from right */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 299;
    background: var(--bg-primary);
    transform: translateX(100%);
    transition: transform 0.48s cubic-bezier(0.76, 0, 0.24, 1);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mobile-menu.is-open {
    transform: translateX(0);
  }

  .mobile-inner {
    min-height: 100svh;
    padding: 88px 28px 48px; /* 88px clears the fixed header */
    display: flex;
    flex-direction: column;
  }

  /* NAV LINKS */
  .mobile-nav {
    list-style: none;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 16px 0 40px;
    gap: 0;
  }

  .mobile-nav li {
    border-bottom: 1px solid var(--border-line);
    opacity: 0;
    transform: translateX(16px);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .mobile-nav li:first-child { border-top: 1px solid var(--border-line); }

  /* Staggered entrance via CSS custom property --i */
  .mobile-menu.is-open .mobile-nav li {
    opacity: 1;
    transform: translateX(0);
    transition:
      opacity 0.4s ease calc(0.07s * var(--i) + 0.18s),
      transform 0.4s ease calc(0.07s * var(--i) + 0.18s);
  }

  .mobile-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 20px 0;
    color: var(--text-primary);
    transition: color 0.25s ease;
    gap: 16px;
  }

  .mobile-link:active,
  .mobile-link:focus-visible {
    color: var(--accent-blood);
  }

  .link-name {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1;
    font-variation-settings: "opsz" 144, "SOFT" 20;
    transition: color 0.25s ease;
  }

  .link-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--accent-blood);
    font-weight: 500;
    opacity: 0.6;
    align-self: flex-end;
    padding-bottom: 4px;
    flex-shrink: 0;
  }

  /* MENU FOOTER */
  .mobile-footer {
    padding-top: 28px;
    border-top: 1px solid var(--border-line);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mobile-lang {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .mobile-lang a { color: var(--text-muted); padding: 4px; transition: color 0.2s ease; }
  .mobile-lang a.active { color: var(--text-primary); }
  .mobile-lang .sep { color: var(--text-subtle); }

  .mobile-tagline {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .site-header { padding: 0 20px; }
    .nav-cluster { display: none; }
    .mobile-toggle { display: flex; }
  }

  :global(body.menu-open) { overflow: hidden; }
</style>

<script>
  const toggle = document.getElementById('mobile-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');
  const links = menu?.querySelectorAll('a');

  function openMenu() {
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Cerrar menú');
    menu?.classList.add('is-open');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.classList.add('menu-open');
  }

  function closeMenu() {
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Abrir menú');
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('menu-open');
  }

  toggle?.addEventListener('click', () => {
    toggle.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
  });

  links?.forEach(link => link.addEventListener('click', closeMenu));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
